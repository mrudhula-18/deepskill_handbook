# Base URL of the REST API this SPA talks to.
# Point this at the Week 3 Module 9 Spring Boot backend (or any REST API
# exposing the same /api/books shape: id, title, author, isbn, price).
#
# Copy this file to `.env` and adjust the value if your backend runs on a
# different host/port:
#   cp .env.example .env
VITE_API_BASE_URL=http://localhost:8080/api
