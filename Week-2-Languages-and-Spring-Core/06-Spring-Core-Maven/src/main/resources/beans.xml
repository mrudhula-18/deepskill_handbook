<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Alternate, XML-defined engine beans (independent of component scanning) -->
    <bean id="petrolEngine" class="com.dn5.week2.springcore.PetrolEngine" />
    <bean id="dieselEngine" class="com.dn5.week2.springcore.DieselEngine" />

    <!--
        Alternate Car bean wired via plain XML configuration, using the
        diesel engine bean defined above via constructor-arg reference.
    -->
    <bean id="xmlCar" class="com.dn5.week2.springcore.Car">
        <constructor-arg ref="dieselEngine" />
    </bean>

</beans>
